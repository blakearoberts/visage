{
  "tabWidth": 2,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "trailingComma": "all",
  "useTabs": false,
  "bracketSpacing": true,
  "plugins": ["@blakearoberts/prettier-plugin-helm"],
  "overrides": [
    {
      "files": ["*.md", "**/*.md"],
      "options": {
        "printWidth": 80,
        "proseWrap": "always"
      }
    }
  ]
}
