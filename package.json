{
  "name": "visage-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "check": "npm run check:format && npm run check:type",
    "check:format": "prettier --check .",
    "check:type": "npm run check:type --workspaces --if-present",
    "example": "npm run example:simple",
    "example:simple": "npm --prefix examples/simple run dev",
    "format": "prettier --write .",
    "test": "npm run test --workspaces",
    "test:all": "npm run test:all --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "test:e2e:setup": "npm run test:e2e:setup --workspaces --if-present",
    "test:e2e:setup:examples": "npm run test:e2e:setup:examples --workspaces --if-present"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
