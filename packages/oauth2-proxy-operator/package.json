{
  "name": "@blakearoberts/oauth2-proxy-operator",
  "version": "0.0.0",
  "description": "Kubernetes operator for protecting Gateway API HTTPRoutes via managed oauth2-proxy deployments acting as the relying party in OIDC token grant flows.",
  "type": "module",
  "author": "Blake Roberts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/blakearoberts/visage.git",
    "directory": "packages/oauth2-proxy-operator"
  },
  "homepage": "https://github.com/blakearoberts/visage/tree/main/packages/oauth2-proxy-operator#readme",
  "keywords": [
    "gateway-api",
    "kubernetes",
    "oauth2",
    "oauth2-proxy",
    "oidc",
    "operator"
  ],
  "main": "dist/operator.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "test": "true",
    "test:e2e": "for t in 0 1 2; do npm run test:e2e:tier$t || exit; done",
    "test:e2e:tier0": "test/e2e/tier0/run.sh",
    "test:e2e:tier1": "test/e2e/tier1/run.sh",
    "test:e2e:tier2": "test/e2e/tier2/run.sh",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0"
  }
}
