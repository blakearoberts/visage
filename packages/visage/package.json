{
  "name": "@blakearoberts/visage",
  "version": "0.0.4",
  "description": "Vite plugin for local development with HMR and OIDC session cookie lifecycle semantics.",
  "type": "module",
  "author": "Blake Roberts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/blakearoberts/visage.git",
    "directory": "packages/visage"
  },
  "bugs": {
    "url": "https://github.com/blakearoberts/visage/issues"
  },
  "homepage": "https://github.com/blakearoberts/visage/tree/main/packages/visage#readme",
  "keywords": [
    "authentication",
    "hmr",
    "local-development",
    "oauth2",
    "oidc",
    "pkce",
    "session-cookie",
    "vite",
    "vite-plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docker-compose.images.yml"
  ],
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "rollup -c",
    "check": "npm run typecheck",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "eta": "^4.6.0",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^26.1.1",
    "rollup": "^4.62.2",
    "tslib": "^2.8.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  }
}
